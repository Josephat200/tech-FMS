NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1
TRUST_PROXY=1
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Must be a strong random value (min 32 chars). Do not commit real secrets.
JWT_SECRET=replace-with-strong-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
SHUTDOWN_GRACE_PERIOD_MS=10000

# Database
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=tech_rica
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Logging and rate limit
LOG_LEVEL=info
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300

# Assistant mode:
# - rules: no external AI provider required (recommended safe default)
# - provider: requires provider URL/model; cloud OpenAI also requires API key
AI_ASSISTANT_MODE=rules
AI_ASSISTANT_BASE_URL=
AI_ASSISTANT_MODEL=
AI_ASSISTANT_API_KEY=
OPENAI_API_KEY=

# MFA
MFA_ENABLED=true
MFA_CODE_EXPIRES_MINUTES=10
MFA_MAX_ATTEMPTS=5
MFA_DEV_BYPASS_CODE=

# Optional one-time admin bootstrap (run and then remove from env)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_FIRST_NAME=
BOOTSTRAP_ADMIN_LAST_NAME=
