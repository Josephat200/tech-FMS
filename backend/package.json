{
  "name": "tech-rica-fms-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Node.js (Express) backend for TECH.RICA FMS",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "migrate": "tsx src/scripts/migrate.ts up",
    "migrate:prod": "node dist/scripts/migrate.js up",
    "migrate:status": "tsx src/scripts/migrate.ts status",
    "migrate:status:prod": "node dist/scripts/migrate.js status",
    "bootstrap:admin": "tsx src/scripts/bootstrap-admin.ts",
    "predeploy": "npm run test && npm run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand tests/unit",
    "test:integration": "jest --runInBand tests/integration",
    "test:accounting": "jest --runInBand tests/accounting",
    "test:security": "jest --runInBand tests/security",
    "test:api": "jest --runInBand tests/api"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.15",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.11.1",
    "prettier": "^3.3.3",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.1",
    "@types/jest": "^29.5.13",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  }
}