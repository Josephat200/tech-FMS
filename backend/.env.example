NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
TRUST_PROXY=1
CORS_ALLOWED_ORIGINS=http://localhost:5173
JWT_SECRET=change_me_with_at_least_32_characters_secret_value
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
SHUTDOWN_GRACE_PERIOD_MS=10000
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tech_rica
DB_USER=postgres
DB_PASSWORD=postgres
LOG_LEVEL=info
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300
# Use 'rules' by default for safe startup; switch to 'provider' in production only after setting provider URL/model and API key.
AI_ASSISTANT_MODE=rules
AI_ASSISTANT_BASE_URL=https://api.openai.com/v1
AI_ASSISTANT_API_KEY=
OPENAI_API_KEY=
AI_ASSISTANT_MODEL=gpt-4o-mini
MFA_ENABLED=false
MFA_CODE_EXPIRES_MINUTES=10
MFA_MAX_ATTEMPTS=5
MFA_DEV_BYPASS_CODE=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_FIRST_NAME=
BOOTSTRAP_ADMIN_LAST_NAME=